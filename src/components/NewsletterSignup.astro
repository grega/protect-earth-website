<section class="PageSection NewsletterSignup" data-variant="muted" id="newsletter">
	<h2 class="PageSection__title">Stay up to date</h2>
	<div class="PageSection__content">
		<form class="NewsletterSignup__form readable-width inline-centered">
			<p>Join our mailing list to keep up with what we're doing to restore natural habitats and boost biodiversity across the UK.</p>

			<p>We don't email too often and you can unsubscribe any time. Your <a href="/privacy-policy">privacy is important to us</a> and your info will not be passed to third parties.</p>

			<p style="display: none;">
				<label>Do not fill this in: <input name="honeyTrap" /></label>
			</p>

			<fieldset>
				<legend class="visually-hidden">Your details</legend>
				<div class="inline-group">
					<div>
						<label for="newsletter-first-name" class="visually-hidden">First Name</label>
						<input
							type="text"
							id="newsletter-first-name"
							name="firstName"
							placeholder="First Name"
							required
						/>
					</div>
					<div>
						<label for="newsletter-last-name" class="visually-hidden">Last Name</label>
						<input
							type="text"
							id="newsletter-last-name"
							name="lastName"
							placeholder="Last Name"
						/>
					</div>
				</div>
				<div>
					<label for="newsletter-email" class="visually-hidden">Email</label>
					<input
						type="email"
						id="newsletter-email"
						name="email"
						placeholder="Email address"
						required
					/>
				</div>
			</fieldset>

			<button type="submit">Subscribe</button>

			<div class="form-message" data-message-container aria-live="assertive"></div>
		</form>
	</div>
</section>

<script>
	document.querySelectorAll('.NewsletterSignup__form').forEach((form) => {
		form.addEventListener('submit', async (e) => {
			e.preventDefault();
			const formEl = e.currentTarget as HTMLFormElement;
			const button = formEl.querySelector('button[type="submit"]') as HTMLButtonElement;
			const messageDiv = formEl.querySelector('[data-message-container]') as HTMLElement;

			button.disabled = true;
			button.textContent = 'Subscribing...';
			messageDiv.removeAttribute('data-status');

			const formData = new FormData(formEl);

			try {
				const response = await fetch('/api/subscribe', {
					method: 'POST',
					headers: { 'Content-Type': 'application/json' },
					body: JSON.stringify({
						email: formData.get('email'),
						firstName: formData.get('firstName'),
						lastName: formData.get('lastName'),
						honeyTrap: formData.get('honeyTrap'),
						list: 'general',
					}),
				});

				const result = await response.json();

				messageDiv.textContent = result.message;
				messageDiv.setAttribute('data-status', result.success ? 'success' : 'error');

				if (result.success) formEl.reset();
			} catch {
				messageDiv.textContent = 'Something went wrong. Please try again.';
				messageDiv.setAttribute('data-status', 'error');
			} finally {
				button.disabled = false;
				button.textContent = 'Subscribe';
			}
		});
	});
</script>
