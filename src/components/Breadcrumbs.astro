---
import ChevronRight from '../assets/icons/chevron-right.svg';
const { pathname } = Astro.url;
const paths = pathname.split('/').filter(Boolean);

const { activeLabel = '' } = Astro.props;

// Create breadcrumb items
const breadcrumbs = [{ label: 'Home', href: '/' }];

let currentPath = '';
paths.forEach((segment, index) => {
	currentPath += `/${segment}`;

	// Format the label (capitalize, replace hyphens with spaces)
	const label = segment
		.split('-')
		.map((word) => word.charAt(0).toUpperCase() + word.slice(1))
		.join(' ');

	breadcrumbs.push({
		label: index === paths.length - 1 ? activeLabel || label : label,
		href: currentPath,
	});
});
---

{
	breadcrumbs.length > 1 && (
		<nav aria-label="Breadcrumb" class="breadcrumbs wrap">
			<ol>
				{breadcrumbs.map((crumb, index) => (
					<li>
						{index > 0 && <ChevronRight height={14} width={14} aria-hidden="true" />}
						<a
							aria-current={index === breadcrumbs.length - 1 ? 'page' : undefined}
							href={crumb.href}
						>
							{crumb.label}
						</a>
					</li>
				))}
			</ol>
		</nav>
	)
}
