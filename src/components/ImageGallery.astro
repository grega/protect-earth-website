---
import { Image } from 'astro:assets';
import Magnify from '../assets/icons/magnifying-glass.svg';
import Next from '../assets/icons/chevron-right.svg';
import Prev from '../assets/icons/chevron-left.svg';
import Close from '../assets/icons/xmark.svg';
import type { ImageMetadata } from 'astro';

interface Props {
	images: ImageMetadata[];
	siteName: string;
}

const { images, siteName } = Astro.props;
const imageUrls = images.map((image) => image.src);

// Only show gallery if there are images
if (!images || images.length === 0) {
	return null;
}
---

<aside class="site-image-gallery">
	<div class="grid image-gallery-grid">
		{
			images.map((image, index) => (
				<div class="gallery-item" data-index={index}>
					<Image src={image} alt={`${siteName} - Image ${index + 1}`} loading="lazy" />
					<div class="gallery-overlay">
						<button
							class="view-button"
							data-image={imageUrls[index]}
							data-index={index}
							aria-label={`View image ${index + 1} in fullscreen`}
						>
							<Magnify height={14} width={14} />
							<span class="visually-hidden">View image</span>
						</button>
					</div>
				</div>
			))
		}
	</div>
</aside>

<!-- Lightbox Modal -->
<div id="lightbox" class="lightbox" role="dialog" aria-modal="true" aria-hidden="true">
	<button class="lightbox-close" aria-label="Close lightbox">
		<Close height={14} width={14} />
	</button>

	<button class="lightbox-nav lightbox-prev" aria-label="Previous image">
		<Prev height={14} width={14} />
	</button>

	<button class="lightbox-nav lightbox-next" aria-label="Next image">
		<Next height={14} width={14} />
	</button>

	<div class="lightbox-content">
		<img id="lightbox-image" src="" alt="" />
		<div class="lightbox-counter">
			<span id="current-image">1</span> / <span id="total-images">{imageUrls.length}</span>
		</div>
	</div>
</div>

<style>
	.site-image-gallery {
		background: var(--grey-light);
		border-radius: var(--radius-m);
		padding: var(--space-m);
	}

	.grid {
		grid-template-columns: var(--grid-fill-12rem);
	}

	.gallery-item {
		position: relative;
		aspect-ratio: 16/9;
		overflow: hidden;
		display: flex;
		justify-content: center;
		align-items: center;
		border-radius: var(--radius-s);
	}

	.gallery-item img {
		border-radius: var(--radius-s);
		object-fit: cover;
	}

	.gallery-overlay {
		position: absolute;
		inset: 0;
		background: var(--black-alpha-50);
		display: flex;
		align-items: center;
		justify-content: center;
		opacity: 0;
		transition: opacity var(--transition);
	}

	.gallery-item:hover .gallery-overlay {
		opacity: 1;
	}

	.view-button {
		color: var(--body-text-light);
		background: var(--link);
		padding: var(--space-2xs);
		border-radius: 500px;
		transition: all var(--transition);
		border: 2px solid var(--border-color);
	}

	.view-button:hover {
		background: var(--link-hover);
		transform: scale(1.1);
	}

	/* Lightbox styles */
	.lightbox {
		position: fixed;
		inset: 0;
		background: var(--black-alpha-90);
		display: none;
		align-items: center;
		justify-content: center;
		z-index: 9999;
		opacity: 0;
		transition: opacity var(--transition);
	}

	.lightbox.active {
		display: flex;
		opacity: 1;
	}

	.lightbox-content {
		position: relative;
		max-width: 85vw;
		max-height: 85vh;
		display: flex;
		flex-direction: column;
		align-items: center;
	}

	#lightbox-image {
		max-width: 100%;
		max-height: 85vh;
		object-fit: contain;
		border-radius: var(--radius-m);
		box-shadow: 0 25px 50px -12px var(--black-alpha-50);
	}

	.lightbox-close {
		position: absolute;
		top: var(--space-xs);
		right: var(--space-xs);
		color: var(--body-text-light);
		background: var(--black-alpha-90);
		padding: var(--space-xs);
		border-radius: 500px;
		transition: all var(--transition);
		z-index: 10001;
	}

	.lightbox-close:hover {
		background: var(--link-hover);
	}

	.lightbox-nav {
		position: absolute;
		top: 50%;
		transform: translateY(-50%);
		color: white;
		background: var(--black-alpha-90);
		padding: var(--space-xs);
		border-radius: 500px;
		transition: all var(--transition);
		z-index: 10001;
	}

	.lightbox-nav:hover {
		background: var(--link-hover);
	}

	.lightbox-prev {
		left: var(--space-xs);
	}

	.lightbox-next {
		right: var(--space-xs);
	}

	.lightbox-counter {
		color: var(--body-text-light);
		font-size: var(--font-xs);
		font-weight: 700;
		text-align: center;
		padding: var(--font-2xs) var(--font-xs);
		border-radius: var(--radius-s);
	}

	@media (max-width: 640px) {
		.lightbox-nav {
			padding: 0.5rem;
		}

		.lightbox-nav svg {
			width: 1.5rem;
			height: 1.5rem;
		}

		.lightbox-close svg {
			width: 1.5rem;
			height: 1.5rem;
		}
	}
</style>

<script is:inline define:vars={{ imageUrls }}>
	let currentImageIndex = 0;

	// Open lightbox
	document.querySelectorAll('.view-button').forEach((button) => {
		button.addEventListener('click', (e) => {
			e.stopPropagation();
			const index = parseInt(button.dataset.index);
			openLightbox(index);
		});
	});

	// Also allow clicking on the gallery item itself
	document.querySelectorAll('.gallery-item').forEach((item) => {
		item.addEventListener('click', () => {
			const index = parseInt(item.dataset.index);
			openLightbox(index);
		});
	});

	function openLightbox(index) {
		currentImageIndex = index;
		const lightbox = document.getElementById('lightbox');
		const lightboxImage = document.getElementById('lightbox-image');
		const currentImageEl = document.getElementById('current-image');

		lightboxImage.src = imageUrls[currentImageIndex];
		lightboxImage.alt = `Gallery image ${currentImageIndex + 1}`;
		currentImageEl.textContent = currentImageIndex + 1;

		lightbox.classList.add('active');
		lightbox.setAttribute('aria-hidden', 'false');
		document.body.style.overflow = 'hidden';
	}

	function closeLightbox() {
		const lightbox = document.getElementById('lightbox');
		lightbox.classList.remove('active');
		lightbox.setAttribute('aria-hidden', 'true');
		document.body.style.overflow = '';
	}

	function showNextImage() {
		currentImageIndex = (currentImageIndex + 1) % imageUrls.length;
		updateLightboxImage();
	}

	function showPrevImage() {
		currentImageIndex = (currentImageIndex - 1 + imageUrls.length) % imageUrls.length;
		updateLightboxImage();
	}

	function updateLightboxImage() {
		const lightboxImage = document.getElementById('lightbox-image');
		const currentImageEl = document.getElementById('current-image');

		lightboxImage.src = imageUrls[currentImageIndex];
		lightboxImage.alt = `Gallery image ${currentImageIndex + 1}`;
		currentImageEl.textContent = currentImageIndex + 1;
	}

	// Close button
	document.querySelector('.lightbox-close')?.addEventListener('click', closeLightbox);

	// Navigation buttons
	document.querySelector('.lightbox-prev')?.addEventListener('click', showPrevImage);
	document.querySelector('.lightbox-next')?.addEventListener('click', showNextImage);

	// Close on backdrop click
	document.getElementById('lightbox')?.addEventListener('click', (e) => {
		if (e.target.id === 'lightbox') {
			closeLightbox();
		}
	});

	// Keyboard navigation
	document.addEventListener('keydown', (e) => {
		const lightbox = document.getElementById('lightbox');
		if (!lightbox.classList.contains('active')) return;

		if (e.key === 'Escape') {
			closeLightbox();
		} else if (e.key === 'ArrowRight') {
			showNextImage();
		} else if (e.key === 'ArrowLeft') {
			showPrevImage();
		}
	});
</script>
