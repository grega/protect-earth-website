---
import type { Page } from 'astro';
import ChevronLeft from './../assets/icons/chevron-left.svg';
import ChevronRight from './../assets/icons/chevron-right.svg';

type Props = Page;

const { currentPage, lastPage, url } = Astro.props;
---

<nav class="pagination" aria-label="pagination">
	{
		url.prev && (
			<a class="pagination-nav pagination-previous" href={url.prev}>
				<ChevronLeft width={18} height={18} />
				Previous
			</a>
		)
	}

	<div class="pagination-pages">
		{
			Array.from({ length: lastPage }, (_, i) => i + 1).map((pageNum) => (
				<a
					href={pageNum === 1 ? '/articles' : `/articles/${pageNum}`}
					aria-current={pageNum === currentPage ? 'page' : undefined}
				>
					{pageNum}
				</a>
			))
		}
	</div>

	{
		url.next && (
			<a class="pagination-nav pagination-next" href={url.next}>
				Next
				<ChevronRight width={18} height={18} />
			</a>
		)
	}
</nav>

<style>
	.pagination {
		display: flex;
		align-items: center;
		justify-content: center;
		gap: var(--space-m);
		font-size: var(--font-s);
	}

	.pagination a {
		text-decoration: none;
		background: var(--grey-light);
		border-radius: 500px;
		display: inline-flex;
		align-items: center;
		justify-content: center;
		color: var(--body-text);
	}

	.pagination-pages {
		display: flex;
		gap: var(--space-xs);
	}

	.pagination-pages a {
		aspect-ratio: 1/1;
		padding: var(--space-2xs);
		width: 3rem;
	}

	.pagination a:hover,
	.pagination-pages a[aria-current='page'] {
		background: var(--black);
		color: var(--body-text-light);
	}

	.pagination-nav {
		gap: var(--space-3xs);
		padding: var(--space-2xs) var(--space-s);
	}
</style>
