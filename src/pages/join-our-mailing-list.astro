---
import ContentHero from '../components/ContentHero.astro';
import TakeAction from '../components/TakeAction.astro';
import Layout from '../layouts/Layout.astro';
---

<Layout title="Join Our Mailing List">
	<ContentHero variant="tertiary" title="Join Our Mailing List">
		<p>Stay connected with our conservation work</p>
	</ContentHero>

	<div class="PageSection">
		<div class="PageSection__content">
			<form id="mailing-list-form" class="readable-width inline-centered">
				<!-- What are you interested in hearing about? -->
				<fieldset>
					<legend>
						What are you interested in hearing about? <span class="field-required">*</span>
					</legend>
					<div class="stacked-options">
						<label>
							<input type="checkbox" name="interests" value="general" />
							<span>General updates</span>
						</label>
						<label>
							<input type="checkbox" name="interests" value="events" />
							<span>Planting events</span>
						</label>
					</div>
				</fieldset>

				<!-- Name -->
				<fieldset>
					<legend>
						Name <span class="field-required">*</span>
					</legend>
					<div class="inline-group">
						<div>
							<label for="first-name" class="visually-hidden">First Name</label>
							<input
								type="text"
								id="first-name"
								name="firstName"
								placeholder="First Name"
								required
							/>
						</div>
						<div>
							<label for="last-name" class="visually-hidden">Last Name</label>
							<input type="text" id="last-name" name="lastName" placeholder="Last Name" required />
						</div>
					</div>
				</fieldset>

				<!-- Email -->
				<div>
					<label for="email">
						Email <span class="field-required">*</span>
					</label>
					<input type="email" id="email" name="email" required placeholder="your@email.com" />
				</div>

				<!-- Volunteer Region -->
				<div>
					<label for="region">
						Do you see yourself volunteering? Please let us know which region you're in.
						<span class="field-required">*</span>
					</label>
					<textarea
						id="region"
						name="region"
						rows="3"
						required
						placeholder="Tell us about your location and interest in volunteering..."></textarea>
				</div>

				<!-- Submit Button -->
				<div>
					<button type="submit">Submit</button>
				</div>

				<!-- Success/Error Messages -->
				<div id="form-message" aria-live="assertive" class="form-message"></div>

				<footer class="mt-8 text-center text-gray-600">
					<small>
						We respect your privacy. Your information will only be used to send you updates about
						Protect Earth's conservation work.
					</small>
				</footer>
			</form>
		</div>
	</div>

	<TakeAction />
</Layout>

<script>
	const form = document.getElementById('mailing-list-form') as HTMLFormElement;
	const messageDiv = document.getElementById('form-message') as HTMLDivElement;

	form?.addEventListener('submit', async (e) => {
		e.preventDefault();

		const formData = new FormData(form);
		const interests = formData.getAll('interests');

		// Validate at least one interest is selected
		if (interests.length === 0) {
			showMessage('Please select at least one interest.', 'error');
			return;
		}

		// Here you would integrate with Mailchimp's API
		// For now, we'll show a placeholder message
		// TODO: Replace with actual Mailchimp API endpoint

		const data = {
			firstName: formData.get('firstName'),
			lastName: formData.get('lastName'),
			email: formData.get('email'),
			interests: interests,
			region: formData.get('region'),
		};

		console.log('Form data:', data);

		// Placeholder: Show success message
		// In production, you would POST to Mailchimp API here
		showMessage(
			'Thank you for signing up! You should receive a confirmation email shortly.',
			'success',
		);
		form.reset();
	});

	function showMessage(message: string, type: 'success' | 'error') {
		if (!messageDiv) return;

		messageDiv.textContent = message;
		messageDiv.setAttribute('data-status', type);

		// Hide message after 5 seconds
		setTimeout(() => {
			messageDiv.removeAttribute('data-status');
		}, 5000);
	}
</script>
