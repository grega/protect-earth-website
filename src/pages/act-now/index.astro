---
import Layout from '../../layouts/Layout.astro';
import ContentHero from '../../components/ContentHero.astro';
import SectionCard from '../../components/SectionCard.astro';
---

<Layout title="Act Now">
	<ContentHero
		imgSrc="/hero-donate.jpg"
		imgAlt="Group of people planting young trees in a row in a field"
		title="Act Now"
	>
		<p>Take action to protect the Earth</p>
	</ContentHero>

	<section class="PageSection">
		<div class="PageSection__content">
			<nav aria-label="Ways to take action">
				<ul class="SectionCards">
					<SectionCard
						href="/act-now/sponsor-trees"
						title="Sponsor Trees"
						description="Fund tree planting and maintenance"
					/>
					<SectionCard
						href="/act-now/general-donation"
						title="General Donation"
						description="Support our work"
					/>
					<SectionCard
						href="/act-now/land-fund"
						title="Land Fund"
						description="Help us acquire land for conservation"
					/>
				</ul>
			</nav>
		</div>
	</section>
</Layout>
