---
import Layout from '../../layouts/Layout.astro';
---

<Layout title="Act Now">
	<section class="bg-green-700 text-white py-20">
		<div class="container mx-auto px-4 text-center">
			<h1 class="text-5xl font-bold mb-6">Act Now</h1>
			<p class="text-xl max-w-3xl mx-auto">Take action to protect the Earth</p>
		</div>
	</section>

	<section class="py-16">
		<div class="container mx-auto px-4">
			<div class="grid grid-cols-1 md:grid-cols-3 gap-8">
				<a href="/act-now/sponsor-trees" class="bg-white border border-gray-200 rounded-lg p-8 hover:shadow-lg transition">
					<h3 class="text-2xl font-bold mb-4 text-green-800">Sponsor Trees</h3>
					<p class="text-gray-600">Fund tree planting and maintenance</p>
				</a>
				<a href="/act-now/general-donation" class="bg-white border border-gray-200 rounded-lg p-8 hover:shadow-lg transition">
					<h3 class="text-2xl font-bold mb-4 text-green-800">General Donation</h3>
					<p class="text-gray-600">Support our work</p>
				</a>
				<a href="/act-now/land-fund" class="bg-white border border-gray-200 rounded-lg p-8 hover:shadow-lg transition">
					<h3 class="text-2xl font-bold mb-4 text-green-800">Land Fund</h3>
					<p class="text-gray-600">Help us acquire land for conservation</p>
				</a>
			</div>
		</div>
	</section>
</Layout>
