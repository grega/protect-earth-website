---
import { getCollection } from 'astro:content';
import Layout from '../../layouts/Layout.astro';
import ContentHero from '../../components/ContentHero.astro';
import PressArticle from '../../components/PressArticle.astro';

const [pressArticles] = await getCollection('press');
const articles = pressArticles.data ?? [];
---

<Layout title="In the Press">
	<!-- Hero Section with Background Image -->
	<ContentHero
		imgSrc="/hero-press.jpg"
		imgAlt="Forest path through pine trees"
		title="In the Press"
	>
		<p>Coverage of Protect Earth's mission to rewild Britain and protect our natural heritage</p>
	</ContentHero>

	<!-- Press Articles Grid -->
	<section class="PageSection">
		<div class="PageSection__content">
			<div class="PressArticles">
				{articles.map((article) => <PressArticle {...article} />)}
			</div>
		</div>
	</section>
</Layout>
