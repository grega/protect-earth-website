---
import Layout from '../../layouts/Layout.astro';
import CallToAction from '../../components/CallToAction.astro';
import { load } from 'js-yaml';
import { readFileSync } from 'fs';
import { join } from 'path';

// Load team members from YAML
const yamlPath = join(process.cwd(), 'src/data/team.yaml');
const yamlContent = readFileSync(yamlPath, 'utf8');
const data = load(yamlContent) as { members: Array<{
	name: string;
	role: string;
	image: string;
	bio: string;
}> };

const members = data.members;
---

<Layout title="Meet the Team">
	<!-- Hero Section with Background Image -->
	<section class="relative bg-gray-900 text-white">
		<div class="absolute inset-0">
			<img src="/hero-team.jpg" alt="Dense forest with sunlight filtering through trees" class="w-full h-full object-cover opacity-50" />
		</div>
		<div class="relative max-w-4xl mx-auto px-4 sm:px-6 lg:px-8 py-24">
			<h1 class="text-5xl font-bold mb-6">Meet The Team</h1>
		</div>
	</section>

	<!-- Team Members -->
	<section class="py-16 bg-white">
		<div class="max-w-5xl mx-auto px-4 sm:px-6 lg:px-8">
			<div class="space-y-16">
				{members.map((member) => (
					<div class="flex flex-col md:flex-row gap-8 items-start">
						<div class="md:w-1/3 flex-shrink-0">
							<img src={member.image} alt={member.name} class="w-full aspect-square object-cover rounded-lg shadow-lg" />
						</div>
						<div class="md:w-2/3">
							<h2 class="text-3xl font-bold text-gray-900 mb-2">{member.name}</h2>
							<p class="text-xl text-green-700 font-semibold mb-4">{member.role}</p>
							<div class="prose prose-lg text-gray-700 whitespace-pre-line">
								{member.bio}
							</div>
						</div>
					</div>
				))}
			</div>
		</div>
	</section>

	<CallToAction />
</Layout>
