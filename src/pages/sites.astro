---
import { getCollection } from 'astro:content';
import { Image } from 'astro:assets';
import Layout from '../layouts/Layout.astro';
import CallToAction from '../components/CallToAction.astro';
import { siteConfig } from '../config';

const mapboxToken = import.meta.env.PUBLIC_MAPBOX_TOKEN;

// Fetch sites from API
const apiResponse = await fetch('https://api.protect.earth/sites');
const allApiSites = await apiResponse.json();
// Filter out ignored sites
const apiSites = allApiSites.filter((site: any) => 
  !siteConfig.ignoredSites.includes(site.name)
);

// Get collection for tags
const siteCollection = await getCollection('sites');
const siteTagsMap = new Map(
  siteCollection.map(site => [site.slug, site.data.tags || []])
);

// Helper to convert to kebab-case
function toKebabCase(str: string): string {
  return str
    .toLowerCase()
    .replace(/[^\w\s-]/g, '')
    .replace(/\s+/g, '-')
    .replace(/--+/g, '-')
    .trim();
}

// Map API data with first image and tags
const sites = apiSites
  .map((site: any) => {
    const slug = toKebabCase(site.name);
    return {
      id: site.id,
      name: site.name,
      location: site.location,
      url: site.url,
      allocatedUnits: site.allocatedUnits,
      coordinates: site.coordinates,
      slug: slug,
      thumbnail: site.images?.[0] || null,
      tags: siteTagsMap.get(slug) || [],
    };
  })
  .sort((a: any, b: any) => a.name.localeCompare(b.name));

// Get all unique tags
const allTags = [...new Set(sites.flatMap((site: any) => site.tags))].sort();
---

<Layout title="Sites">
	<!-- Hero Section -->
	<section class="relative bg-gray-900 text-white">
		<div class="absolute inset-0 bg-gradient-to-b from-gray-900 to-gray-800"></div>
		<div class="relative max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-24">
			<h1 class="text-5xl font-bold mb-6">Our Sites</h1>
			<p class="text-xl text-gray-300">Discover the woodlands, shelterbelts, and rewilding projects we've created across the UK.</p>
		</div>
	</section>

	<!-- Map Section -->
	<section class="py-12 bg-gray-50">
		<div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
			<div id="map" class="w-full h-96 rounded-lg shadow-lg"></div>
		</div>
	</section>

	<!-- Sites Grid -->
	<section class="py-16 bg-white">
		<div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
			<!-- Filter Tags -->
			{allTags.length > 0 && (
				<div class="mb-8">
					<h2 class="text-lg font-semibold text-gray-700 mb-4">Filter by type:</h2>
					<div class="flex flex-wrap gap-3">
						<button 
							class="filter-tag active px-4 py-2 text-sm font-medium rounded-full transition-colors border-2 border-green-600 bg-green-600 text-white hover:bg-green-700 hover:border-green-700"
							data-tag="all"
						>
							All Sites
						</button>
						{allTags.map((tag) => (
							<button 
								class="filter-tag px-4 py-2 text-sm font-medium rounded-full transition-colors border-2 border-gray-300 bg-white text-gray-700 hover:border-green-600 hover:text-green-600"
								data-tag={tag}
							>
								{tag}
							</button>
						))}
					</div>
					<p class="mt-4 text-sm text-gray-600">
						Showing <span id="site-count" class="font-semibold">{sites.length}</span> sites
					</p>
				</div>
			)}
			
			<div id="sites-grid" class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8">
				{sites.map((site) => (
					<a href={`/sites/${site.slug}`} class="group site-card" data-tags={JSON.stringify(site.tags)}>
						<article class="bg-white rounded-lg shadow-md overflow-hidden hover:shadow-xl transition-shadow duration-300">
							{site.thumbnail ? (
								<div class="aspect-video overflow-hidden bg-gray-200">
									<img 
										src={site.thumbnail} 
										alt={site.name}
										class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-300"
									/>
								</div>
							) : (
								<div class="aspect-video bg-gradient-to-br from-green-100 to-green-200 flex items-center justify-center">
									<svg class="w-24 h-24 text-green-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
										<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 3v4M3 5h4M6 17v4m-2-2h4m5-16l2.286 6.857L21 12l-5.714 2.143L13 21l-2.286-6.857L5 12l5.714-2.143L13 3z" />
									</svg>
								</div>
							)}
							<div class="p-6">
								<h2 class="text-2xl font-bold mb-2 text-gray-900 group-hover:text-green-700 transition">
									{site.name}
								</h2>
								{site.location && (
									<p class="text-sm text-gray-500 mb-3">
										📍 {site.location}
									</p>
								)}
								{site.tags && site.tags.length > 0 && (
									<div class="flex flex-wrap gap-2">
										{site.tags.map((tag: string) => (
											<span class="inline-block px-3 py-1 text-xs font-medium bg-green-100 text-green-800 rounded-full">
												{tag}
											</span>
										))}
									</div>
								)}
							</div>
						</article>
					</a>
				))}
			</div>
		</div>
	</section>

	<CallToAction />
</Layout>
<!-- Mapbox GL JS -->
<link href='https://api.mapbox.com/mapbox-gl-js/v2.8.2/mapbox-gl.css' rel='stylesheet' />
<script src='https://api.mapbox.com/mapbox-gl-js/v2.8.2/mapbox-gl.js'></script>
<script define:vars={{ sites, mapboxToken }}>
	window.addEventListener('DOMContentLoaded', () => {
		mapboxgl.accessToken = mapboxToken;
		
		const map = new mapboxgl.Map({
			container: 'map',
			style: 'mapbox://styles/mapbox/light-v10',
      center: [-1.8373, 53.7454], // the middle of the UK roughly
			zoom: 4.5
		});

		map.addControl(new mapboxgl.NavigationControl());

		sites.forEach(site => {
			if (!site.coordinates || !site.coordinates.latitude || !site.coordinates.longitude) return;
			
			const popup = new mapboxgl.Popup({ offset: 25 }).setHTML(`
				<div class="p-2">
					<h3 class="font-bold mb-2">${site.name}</h3>
					${site.location ? `<p class="text-sm mb-1">${site.location}</p>` : ''}
					${site.allocatedUnits > 0 ? `<p class="text-sm mb-2">${site.allocatedUnits.toLocaleString()} trees</p>` : ''}
					<a href="/sites/${site.slug}" class="text-green-700 hover:underline text-sm">
						View Site →
					</a>
				</div>
			`);

			new mapboxgl.Marker({ color: '#15803d' })
				.setLngLat([site.coordinates.longitude, site.coordinates.latitude])
				.setPopup(popup)
				.addTo(map);
		});
	});
</script>
<script>
	// Tag filtering functionality
	document.addEventListener('DOMContentLoaded', () => {
		const filterButtons = document.querySelectorAll('.filter-tag');
		const siteCards = document.querySelectorAll('.site-card');
		const siteCountEl = document.getElementById('site-count');
		
		let activeTag = 'all';
		
		filterButtons.forEach(button => {
			button.addEventListener('click', () => {
				const tag = button.dataset.tag;
				
				// Update active state
				filterButtons.forEach(btn => {
					if (btn.dataset.tag === tag) {
						btn.classList.add('active', 'bg-green-600', 'text-white', 'border-green-600');
						btn.classList.remove('bg-white', 'text-gray-700', 'border-gray-300');
					} else {
						btn.classList.remove('active', 'bg-green-600', 'text-white', 'border-green-600');
						btn.classList.add('bg-white', 'text-gray-700', 'border-gray-300');
					}
				});
				
				activeTag = tag;
				filterSites();
			});
		});
		
		function filterSites() {
			let visibleCount = 0;
			
			siteCards.forEach(card => {
				const tags = JSON.parse(card.dataset.tags || '[]');
				
				if (activeTag === 'all' || tags.includes(activeTag)) {
					card.style.display = '';
					visibleCount++;
				} else {
					card.style.display = 'none';
				}
			});
			
			if (siteCountEl) {
				siteCountEl.textContent = visibleCount;
			}
		}
	});
</script>