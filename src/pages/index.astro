---
import Layout from '../layouts/Layout.astro';
import { siteConfig } from '../config';
import { getCollection } from 'astro:content';
import GetStarted from '../components/GetStarted.astro';
import TakeAction from '../components/TakeAction.astro';
import NewsletterSignup from '../components/NewsletterSignup.astro';
import ArticleSummary from '../components/ArticleSummary.astro';

const latestPosts = (await getCollection('articles'))
	.sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf())
	.slice(0, 4)
	.map((post) => ({ slug: post.id, data: post.data }));
---

<Layout title="Home">
	<section class="PageSection" data-layout="stacked">
		<div class="PageSection__content">
			<h1 class="PageSection__title">The Earth is in trouble. We're doing something about it.</h1>
			<p>
				Protect Earth creates and restores woodlands, meadows, and hedgerows in the UK — helping to
				combat the escalating climate and biodiversity crises.
			</p>
			<p>
				The advantages of creating and restoring natural ecosystems are many: removing carbon from
				the atmosphere, reducing the risk of flooding, and enhancing air quality.
			</p>
			<p>
				We work with landowners, environmental organisations, businesses and the general public to
				achieve outcomes that benefit everyone.
			</p>
		</div>

		<div class="PageSection__background">
			<video
				class="PageSection__media"
				id="hero-video"
				preload="auto"
				autoplay
				loop
				muted
				playsinline
			>
				<source src="/hero-video.mp4" type="video/mp4" />
			</video>
		</div>
	</section>

	<div class="PageSection">
		<div class="PageSection__content">
			<GetStarted />
		</div>
	</div>

	<section class="PageSection">
		<h2 class="PageSection__title">Our Achievements</h2>

		<ul class="Achievements">
			<li class="Achievement">
				<strong class="Achievement__value">
					{siteConfig.achievements.treesPlanted.toLocaleString()}
				</strong>
				<span class="Achievement__label">trees planted</span>
			</li>
			<li class="Achievement">
				<strong class="Achievement__value">
					{siteConfig.achievements.acresRestored.toLocaleString()}
				</strong>
				<span class="Achievement__label">acres restored</span>
			</li>
			<li class="Achievement">
				<strong class="Achievement__value">
					{siteConfig.achievements.acresUnderManagement.toLocaleString()}
				</strong>
				<span class="Achievement__label">acres under direct management</span>
			</li>
		</ul>
	</section>

	<section class="PageSection" data-variant="primary">
		<header class="PageSection__header" data-layout="inline">
			<h2 class="PageSection__title">Latest Articles</h2>
			<a href="/articles">View all articles</a>
		</header>

		<div class="PageSection__content article-list">
			{
				latestPosts.map(({ slug, data: article }) => (
					<ArticleSummary {...{ ...article, slug, titleAs: 'h3' }} />
				))
			}
		</div>
	</section>

	<section class="PageSection">
		<h2 class="PageSection__title">Our Funders & Partners</h2>

		<div class="PageSection__content">
			<ul class="LogoList">
				<li class="LogoList__item">
					<img class="LogoList__logo" src="/partner-avon-needs-trees.png" alt="Avon Needs Trees" />
				</li>
				<li class="LogoList__item">
					<img class="LogoList__logo" src="/partner-ecologi.png" alt="Ecologi" />
				</li>
				<li class="LogoList__item">
					<img
						class="LogoList__logo"
						src="/partner-fwag.png"
						alt="Farming and Wildlife Advisory Group"
					/>
				</li>
				<li class="LogoList__item">
					<img class="LogoList__logo" src="/partner-woodland-trust.png" alt="Woodland Trust" />
				</li>
			</ul>
		</div>
	</section>

	<NewsletterSignup />

	<TakeAction />

	<script>
		document.addEventListener('DOMContentLoaded', () => {
			const video = document.getElementById('hero-video') as HTMLVideoElement | null;
			if (video) {
				video.play().catch((err) => console.error('Video play error:', err));
				video.addEventListener('error', (e) => {
					console.error('Video error:', e);
					console.error('Video error details:', video.error);
				});
			}
		});
	</script>
</Layout>
