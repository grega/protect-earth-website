---
import { getCollection } from 'astro:content';
import { Image } from 'astro:assets';
import Layout from '../../layouts/Layout.astro';
import { siteConfig } from '../../config';
import { toKebabCase } from '../../helpers';
import ContentHero from '../../components/ContentHero.astro';
import TakeAction from '../../components/TakeAction.astro';
import MapPin from '../../assets/icons/map-pin.svg';
import NoImage from '../../assets/icons/image.svg';

const mapboxToken = import.meta.env.PUBLIC_MAPBOX_TOKEN;

// Fetch sites from API
const apiResponse = await fetch('https://api.protect.earth/sites');
const allApiSites = await apiResponse.json();

// Filter out ignored sites
const apiSites = allApiSites.filter((site: any) => !siteConfig.ignoredSites.includes(site.name));

// Get collection for tags and local images
const siteMeta = await getCollection('siteMeta');
const siteMetaMap = new Map(
	siteMeta.map((site) => [
		site.id,
		{
			tags: site.data.tags || [],
			thumbnail: site.data.images?.[0] || null,
		},
	]),
);

// Map API data with first image and tags
const sites = apiSites
	.map((site: any) => {
		const slug = toKebabCase(site.name);
		const meta = siteMetaMap.get(slug);

		return {
			slug,
			id: site.id,
			name: site.name,
			location: site.location,
			url: site.url,
			allocatedUnits: site.allocatedUnits,
			coordinates: site.coordinates,
			localThumbnail: meta?.thumbnail || null,
			remoteThumbnail: site.images?.[0] || null,
			tags: meta?.tags || [],
		};
	})
	.sort((a: any, b: any) => a.name.localeCompare(b.name));

// Get all unique tags
const allTags = [...new Set(sites.flatMap((site: any) => site.tags))].sort();

// Strip image metadata from sites, which isn't needed for Mapbox
const mapSites = sites.map(({ localThumbnail, remoteThumbnail, ...rest }: any) => rest);
---

<Layout title="Sites">
	<!-- Hero Section -->
	<ContentHero title="Our Sites">
		<p>Discover the woodlands, shelterbelts, and rewilding projects we've created across the UK.</p>
	</ContentHero>

	<!-- Map Section -->
	<section class="page-sections wrap">
		<div class="map-box">
			<div id="map" class="map-canvas"></div>
		</div>
		<!-- Sites Grid -->
		<div class="sites">
			<!-- Filter Tags -->
			{
				allTags.length > 0 && (
					<div class="filters">
						<strong>Filter by type:</strong>
						<nav>
							<button type="button" class="button-filter" data-tag="all" aria-pressed="true">
								All Sites
							</button>
							{allTags.map((tag) => (
								<button class="button-filter" data-tag={tag}>
									{tag}
								</button>
							))}
						</nav>
						<p class="results">
							Showing{' '}
							<span id="site-count">
								{sites.length} {`site${sites.length !== 1 ? 's' : ''}`}
							</span>
						</p>
					</div>
				)
			}

			<div id="sites-grid" class="sites-grid">
				{
					sites.map((site: any) => (
						<article class="card site-card" data-tags={JSON.stringify(site.tags)}>
							<a href={`/sites/${site.slug}`}>
								<figure>
									{site.localThumbnail ? (
										<Image
											src={site.localThumbnail}
											alt=""
											width={600}
											height={338}
											loading="lazy"
										/>
									) : site.remoteThumbnail ? (
										<img src={site.remoteThumbnail} alt="" loading="lazy" />
									) : (
										<div class="no-image">
											<NoImage height={36} width={36} />
										</div>
									)}
								</figure>

								<div>
									<h2>{site.name}</h2>

									<ul class="meta">
										{site.location && (
											<li class="location">
												<span class="visually-hidden">Location</span>
												<MapPin height={14} width={14} color={'var(--red-light)'} /> {site.location}
											</li>
										)}
										{site.tags && site.tags.length > 0 && (
											<li class="tags">
												{site.tags.map((tag: string) => (
													<span class="tag">{tag}</span>
												))}
											</li>
										)}
									</ul>
								</div>
							</a>
						</article>
					))
				}
			</div>
		</div>
	</section>

	<TakeAction />
</Layout>

<style>
	a {
		color: var(--body-text);
		text-decoration: none;
	}

	.button-filter {
		appearance: none;
		padding: var(--space-2xs) var(--space-xs);
		background-color: var(--button-filter-background);
		color: var(--button-filter-text);
		border-radius: 500px;
		border: 2px solid var(--button-filter-border);
		font-size: var(--font-2xs);
	}

	.button-filter[aria-pressed='true'],
	.button-filter:hover {
		background-color: var(--button-filter-active);
		border-color: transparent;
		color: var(--button-filter-text-active);
	}

	.filters {
		display: flex;
		flex-flow: column;
		gap: var(--space-s);
		margin-block-end: var(--space-m);
	}

	.filters nav {
		display: flex;
		flex-wrap: wrap;
		gap: var(--space-3xs);
	}

	.sites-grid {
		display: grid;
		grid-template-columns: repeat(auto-fill, minmax(20rem, 1fr));
		gap: var(--space-m);
	}

	.card {
		background-color: var(--white);
		border-radius: var(--radius-m);
	}

	.card a img {
		transition: all var(--transition);
	}

	.card a:hover img {
		transform: scale(102%);
		filter: var(--hover-effect-filter);
	}

	figure {
		aspect-ratio: 16/9;
		overflow: hidden;
		border-top-left-radius: var(--radius-m);
		border-top-right-radius: var(--radius-m);
	}

	.no-image {
		aspect-ratio: 16/9;
		overflow: hidden;
		background: var(--grey-light);
		display: flex;
		align-items: center;
		justify-content: center;
	}

	.card div {
		padding: var(--space-2xs);
		padding-block-end: var(--space-xs);
	}

	.location {
		display: inline-flex;
		gap: var(--space-3xs);
	}

	h2 {
		margin-block-end: var(--space-s);
	}

	.meta {
		display: flex;
		flex-flow: column;
		gap: var(--space-xs);
	}
</style>

<!-- Mapbox GL JS -->
<link href="https://api.mapbox.com/mapbox-gl-js/v2.8.2/mapbox-gl.css" rel="stylesheet" />
<script src="https://api.mapbox.com/mapbox-gl-js/v2.8.2/mapbox-gl.js"></script>
<script is:inline define:vars={{ sites: mapSites, mapboxToken }}>
	window.addEventListener('DOMContentLoaded', () => {
		mapboxgl.accessToken = mapboxToken;

		const map = new mapboxgl.Map({
			container: 'map',
			style: 'mapbox://styles/mapbox/light-v10',
			center: [-1.8373, 53.7454], // the middle of the UK roughly
			zoom: 4.5,
		});

		map.addControl(new mapboxgl.NavigationControl());

		sites.forEach((site) => {
			if (!site.coordinates || !site.coordinates.latitude || !site.coordinates.longitude) return;

			const popup = new mapboxgl.Popup({ offset: 25 }).setHTML(`
				<div class="site-marker-info">
					<h3>${site.name}</h3>
					${site.location ? `<p>${site.location}</p>` : ''}
					${site.allocatedUnits > 0 ? `<p>${site.allocatedUnits.toLocaleString()} trees</p>` : ''}
					<a href="/sites/${site.slug}">
						View Site
					</a>
				</div>
			`);

			new mapboxgl.Marker({ color: '#15803d' })
				.setLngLat([site.coordinates.longitude, site.coordinates.latitude])
				.setPopup(popup)
				.addTo(map);
		});
	});
</script>
<script>
	// Tag filtering functionality
	document.addEventListener('DOMContentLoaded', () => {
		const filterButtons = document.querySelectorAll('.button-filter');
		const siteCards = document.querySelectorAll('.site-card');
		const siteCountEl = document.getElementById('site-count');

		let activeTag = 'all';

		filterButtons.forEach((button) => {
			button.addEventListener('click', () => {
				const tag = (button as HTMLElement).dataset.tag;

				// Update active state
				filterButtons.forEach((btn) => {
					if ((btn as HTMLElement).dataset.tag === tag) {
						btn.setAttribute('aria-pressed', 'true');
					} else {
						btn.removeAttribute('aria-pressed');
					}
				});

				activeTag = tag || '';
				filterSites();
			});
		});

		function filterSites() {
			let visibleCount = 0;

			siteCards.forEach((card) => {
				const tags = JSON.parse((card as HTMLElement).dataset.tags || '[]');

				if (activeTag === 'all' || tags.includes(activeTag)) {
					card.removeAttribute('hidden');
					visibleCount++;
				} else {
					card.setAttribute('hidden', 'true');
				}
			});

			if (siteCountEl) {
				siteCountEl.textContent = `${visibleCount} site${visibleCount === 1 ? '' : 's'}`;
			}
		}
	});
</script>
