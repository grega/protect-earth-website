---
import { getCollection } from "astro:content";
import { Image } from "astro:assets";
import Layout from "../../layouts/Layout.astro";
import CallToAction from "../../components/CallToAction.astro";
import ImageGallery from "../../components/ImageGallery.astro";
import { siteConfig } from "../../config";
import { marked } from "marked";

export const prerender = true;

const mapboxToken = import.meta.env.PUBLIC_MAPBOX_TOKEN;

// Fetch sites from API
const apiResponse = await fetch("https://api.protect.earth/sites");
const allApiSites = await apiResponse.json();
// Filter out ignored sites
const apiSites = allApiSites.filter((site: any) => 
  !siteConfig.ignoredSites.includes(site.name)
);

export async function getStaticPaths() {
	// Helper to convert to kebab-case
	function toKebabCase(str: string): string {
		return str
			.toLowerCase()
			.replace(/[^\w\s-]/g, '')
			.replace(/\s+/g, '-')
			.replace(/--+/g, '-')
			.trim();
	}

	const siteCollection = await getCollection('sites');
	const apiResponse = await fetch('https://api.protect.earth/sites');
	const allApiSites = await apiResponse.json();
	// Filter out ignored sites
	const apiSites = allApiSites.filter((site: any) => 
	  !siteConfig.ignoredSites.includes(site.name)
	);
	
	// Create a map of API data by kebab-case name
	const apiDataMap = new Map();
	apiSites.forEach((site: any) => {
		const kebabSlug = toKebabCase(site.name);
		apiDataMap.set(kebabSlug, site);
	});

	return siteCollection.map((site) => {
		const apiData = apiDataMap.get(site.slug);
		return {
			params: { slug: site.slug },
			props: { site, apiData },
		};
	});
}

const { site, apiData } = Astro.props;

// If site is not found, return 404
if (!site) {
	return Astro.redirect('/404');
}

// Fetch site updates for this site
const allSiteUpdates = await getCollection('site-updates');
const siteNotionIds = site.data.notionIds || [];
const siteUpdates = await Promise.all(
	allSiteUpdates
		.filter((update) => 
			update.data.siteNotionId && siteNotionIds.includes(update.data.siteNotionId)
		)
		.sort((a, b) => {
			if (!a.data.date) return 1;
			if (!b.data.date) return -1;
			return b.data.date.getTime() - a.data.date.getTime();
		})
		.map(async (update) => ({
			...update,
			bodyHtml: update.body ? await marked.parse(update.body) : ""
		}))
);

// Use API data for main info, fallback to collection data
const siteName = apiData?.name || site.slug;
const siteLocation = apiData?.location || "";
const treeCount = apiData?.allocatedUnits || 0;
const coordinates = apiData?.coordinates;
// Use images directly from content collection
const images = site.data.images || [];
const heroImage = images[0] || null;
const fundingPartners = site.data.fundingPartners || [];
const siteDescription = apiData?.description;
const descriptionHtml = siteDescription ? await marked.parse(siteDescription) : "";
const species = apiData?.species || [];

// Funding partner logo mapping
type FundingPartnerInfo = { src: string; alt: string; url: string };
const fundingPartnerLogos = {
	ecologi: {
		src: "/logos/ecologi.png",
		alt: "Ecologi",
		url: "https://ecologi.com/"
	},
	"woodland-trust": {
		src: "/logos/woodland-trust.png",
		alt: "Woodland Trust",
		url: "https://www.woodlandtrust.org.uk/"
	},
	reewild: {
		src: "/logos/reewild.png",
		alt: "Reewild",
		url: "https://www.reewild.co.uk/"
	},
	earthpoints: {
		src: "https://earthpoints.co.uk/wp-content/uploads/elementor/thumbs/earthpoints-logo-raqc5rj02uzbiv5arw3dkgg6s23ksaurwcha6ndgx4.jpg",
		alt: "Earthpoints",
		url: "https://earthpoints.co.uk/"
	}
} as Record<string, FundingPartnerInfo>;

const fundingPartnerInfos = fundingPartners.map(partner => fundingPartnerLogos[partner]).filter(Boolean);
---

<Layout title={siteName} description={siteLocation}>
	<!-- Hero Section -->
	<section class="relative bg-gray-900 text-white">
		{heroImage && (
			<div class="absolute inset-0">
				<Image 
					src={heroImage}
					alt={siteName}
					width={1920}
					height={1080}
					class="w-full h-full object-cover opacity-60"
					loading="eager"
				/>
			</div>
		)}
		<div class="relative max-w-4xl mx-auto px-4 sm:px-6 lg:px-8 py-24">
			<h1 class="text-4xl md:text-5xl font-bold mb-6">{siteName}</h1>
			{siteLocation && (
				<p class="text-xl text-gray-300 mb-4">📍 {siteLocation}</p>
			)}
			{treeCount > 0 && (
				<p class="text-xl text-gray-300">🌳 {treeCount.toLocaleString()} trees planted</p>
			)}
		</div>
	</section>


	<!-- Image Gallery -->
	<ImageGallery images={images} siteName={siteName} />

	<article class="pt-16 pb-6 bg-white">
		<div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8">
			{descriptionHtml && (
				<div class="prose prose-lg max-w-none text-gray-700" set:html={descriptionHtml} />
			)}
      {fundingPartnerInfos.length > 0 && (
				<div class="mb-0 text-center">
					<h3 class="text-lg font-semibold text-gray-700 mb-4">In partnership with</h3>
					<div class="flex flex-wrap items-center justify-center gap-8">
						{fundingPartnerInfos.map((partnerInfo) => (
							<a href={partnerInfo.url} target="_blank" rel="noopener noreferrer" class="inline-block hover:opacity-80 transition-opacity">
								<img 
									src={partnerInfo.src} 
									alt={partnerInfo.alt}
									class="h-20 w-auto"
								/>
							</a>
						))}
					</div>
				</div>
			)}
		</div>
	</article>

	<!-- Species Section -->
	{species.length > 0 && (
	<section class="py-12 bg-green-50">
		<div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8">
			<h2 class="text-3xl font-bold mb-8 text-gray-900">
				<span class="inline-block mr-2">🌱</span>
				Species Planted
			</h2>
			<div class="grid grid-cols-2 sm:grid-cols-3 md:grid-cols-4 gap-3">
				{species.map((sp: any) => (
					<div class="bg-white rounded-lg px-4 py-3 shadow-sm border border-green-100 hover:shadow-md transition-shadow">
						<p class="text-sm font-medium text-gray-800 text-center">{sp.name}</p>
					</div>
				))}
			</div>
		</div>
	</section>
	)}

	<!-- Site Updates Section -->
	{siteUpdates.length > 0 && (
	<section class="py-12 bg-white">
		<div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8">
			<h2 class="text-3xl font-bold mb-8 text-gray-900">
				<span class="inline-block mr-2">📝</span>
				Site Updates
			</h2>
			<div class="space-y-6">
				{siteUpdates.map((update) => (
					<article class="bg-gray-50 rounded-lg p-6 border border-gray-200 hover:border-green-500 transition-colors">
						<div class="flex items-start justify-between mb-3">
							<h3 class="text-xl font-semibold text-gray-900">
                {update.data.date.toLocaleDateString('en-GB', { 
                  year: 'numeric', 
                  month: 'long', 
                })}
              </h3>
						</div>
						
						<div class="flex flex-wrap gap-2 mb-3">
							{update.data.type && (
								<span class="inline-flex items-center px-3 py-1 rounded-full text-sm font-medium bg-green-100 text-green-800">
									{update.data.type}
								</span>
							)}
							{update.data.treesPlanted && (
								<span class="inline-flex items-center px-3 py-1 rounded-full text-sm font-medium bg-blue-100 text-blue-800">
									🌳 {update.data.treesPlanted.toLocaleString()} trees planted
								</span>
							)}
							{update.data.treesRestocked && (
								<span class="inline-flex items-center px-3 py-1 rounded-full text-sm font-medium bg-purple-100 text-purple-800">
									🌱 {update.data.treesRestocked.toLocaleString()} trees restocked
								</span>
							)}
							{update.data.survivalRate != null && (
								<span class="inline-flex items-center px-3 py-1 rounded-full text-sm font-medium bg-emerald-100 text-emerald-800">
									📊 {(update.data.survivalRate * 100).toFixed(0)}% survival rate
								</span>
							)}
						</div>
						
						{update.bodyHtml && (
							<div class="prose prose-sm max-w-none text-gray-700 mb-3" set:html={update.bodyHtml} />
						)}
						
						{update.data.photos && update.data.photos.length > 0 && (
							<div class="mt-4">
								<div class="grid grid-cols-2 md:grid-cols-3 gap-3">
									{update.data.photos.filter(photo => photo.startsWith('/site-updates/')).map((photo) => (
										<a href={photo} target="_blank" rel="noopener noreferrer" class="block">
											<img 
												src={photo} 
												alt={`${update.data.title} photo`}
												class="w-full h-40 object-cover rounded-lg hover:opacity-90 transition-opacity shadow-md"
												loading="lazy"
											/>
										</a>
									))}
								</div>
							</div>
						)}
					</article>
				))}
			</div>
		</div>
	</section>
	)}

	<!-- Map Section -->
	{coordinates && coordinates.latitude && coordinates.longitude && (
	<section class="py-12 bg-gray-50">
		<div class="container mx-auto px-4">
			<h2 class="text-3xl font-bold mb-8 text-center">Site Location</h2>
			<div id="map" class="w-full h-[400px] rounded-lg shadow-lg"></div>
		</div>
	</section>
	)}

	<CallToAction />
</Layout>

<!-- Mapbox GL JS -->
<link href='https://api.mapbox.com/mapbox-gl-js/v2.8.2/mapbox-gl.css' rel='stylesheet' />
<script src='https://api.mapbox.com/mapbox-gl-js/v2.8.2/mapbox-gl.js'></script>

<script define:vars={{ coordinates, siteName, mapboxToken }}>
	if (coordinates && coordinates.latitude && coordinates.longitude) {
		document.addEventListener('DOMContentLoaded', () => {
			mapboxgl.accessToken = mapboxToken;
			
			const map = new mapboxgl.Map({
				container: 'map',
        style: 'mapbox://styles/mapbox/satellite-v9',
				center: [coordinates.longitude, coordinates.latitude],
				zoom: 15
			});

			map.addControl(new mapboxgl.NavigationControl());

			new mapboxgl.Marker({ color: '#15803d' })
				.setLngLat([coordinates.longitude, coordinates.latitude])
				.addTo(map);
		});
	}
</script>
