---
import { getCollection } from 'astro:content';
import { Image } from 'astro:assets';
import { marked } from 'marked';
import ContentHero from '../../components/ContentHero.astro';
import ImageGallery from '../../components/ImageGallery.astro';
import TakeAction from '../../components/TakeAction.astro';
import { siteConfig } from '../../config';
import { toKebabCase } from '../../helpers';
import Layout from '../../layouts/Layout.astro';
import MapPin from '../../assets/icons/map-pin.svg';
import Tree from '../../assets/icons/tree-deciduous.svg';
import PenField from '../../assets/icons/pen-field.svg';
import Seedling from '../../assets/icons/seedling.svg';
import Chart from '../../assets/icons/chart-fft.svg';

export const prerender = true;

export async function getStaticPaths() {
	const apiResponse = await fetch('https://api.protect.earth/sites');
	const allApiSites = await apiResponse.json();

	// Filter out ignored sites
	const apiSites = allApiSites.filter((site: any) => !siteConfig.ignoredSites.includes(site.name));

	const siteCollection = await getCollection('siteMeta');

	// Create a map of API data by kebab-case name
	const apiDataMap = new Map();
	apiSites.forEach((site: any) => {
		const slug = toKebabCase(site.name);
		apiDataMap.set(slug, { ...site, slug });
	});

	return siteCollection.map((site) => {
		const apiData = apiDataMap.get(site.id);
		return {
			params: { slug: site.id },
			props: { site, apiData },
		};
	});
}

const { site, apiData } = Astro.props;

// If site is not found, return 404
if (!site) {
	return Astro.redirect('/404');
}

// Fetch site updates for this site
const allSiteUpdates = await getCollection('siteUpdates');
const siteNotionIds = site.data.notionIds || [];
const siteUpdates = await Promise.all(
	allSiteUpdates
		.filter(
			(update) => update.data.siteNotionId && siteNotionIds.includes(update.data.siteNotionId),
		)
		.map((siteUpdate) => ({
			...siteUpdate,
			data: {
				...siteUpdate.data,
				date: siteUpdate.data.date ? new Date(siteUpdate.data.date) : undefined,
			},
		}))
		.sort((a, b) => {
			if (!a.data.date) return 1;
			if (!b.data.date) return -1;
			return b.data.date.getTime() - a.data.date.getTime();
		})
		.map(async (update) => ({
			...update,
			bodyHtml: update.body ? await marked.parse(update.body) : '',
		})),
);

const mapboxToken = import.meta.env.PUBLIC_MAPBOX_TOKEN;

// Use API data for main info, fallback to collection data
const siteName = apiData?.name || site.id;
const siteLocation = apiData?.location || '';
const treeCount = apiData?.allocatedUnits || 0;
const coordinates = apiData?.coordinates;
// Use images directly from content collection
const images = site.data.images || [];
const heroImage = images[0]?.src || null;
const fundingPartners = site.data.fundingPartners || [];
const siteDescription = apiData?.description;
const descriptionHtml = siteDescription ? await marked.parse(siteDescription) : '';
const species = apiData?.species || [];

// Funding partner logo mapping
type FundingPartnerInfo = { src: string; alt: string; url: string };
const fundingPartnerLogos = {
	ecologi: {
		src: '/logos/funding/ecologi-logo.png',
		alt: 'Ecologi',
		url: 'https://ecologi.com/',
	},
	'woodland-trust': {
		src: '/logos/funding/woodland-trust-logo.png',
		alt: 'Woodland Trust',
		url: 'https://www.woodlandtrust.org.uk/',
	},
	reewild: {
		src: '/logos/funding/reewild-logo.png',
		alt: 'Reewild',
		url: 'https://www.reewild.co.uk/',
	},
	earthpoints: {
		src: 'logos/funding/earthpoints-logo.png',
		alt: 'Earthpoints',
		url: 'https://earthpoints.co.uk/',
	},
} as Record<string, FundingPartnerInfo>;

const fundingPartnerInfos = fundingPartners
	.map((partner) => fundingPartnerLogos[partner])
	.filter(Boolean);
---

<Layout title={siteName} description={siteLocation}>
	<!-- Hero Section -->
	<ContentHero imageAlt="" imgSrc={heroImage} title={siteName}>
		<div>
			{
				siteLocation && (
					<p>
						<MapPin height={24} width={24} /> {siteLocation}
					</p>
				)
			}
			{
				treeCount > 0 && (
					<p>
						<Tree height={24} width={24} /> {treeCount.toLocaleString()} trees planted
					</p>
				)
			}
		</div>
	</ContentHero>

	<section class="page-sections wrap">
		<!-- Image Gallery -->
		<ImageGallery images={images} siteName={siteName} />

		{
			fundingPartnerInfos.length > 0 && (
				<div class="intro">
					{descriptionHtml && (
						<div class="stack prose" data-readable-width="larger" set:html={descriptionHtml} />
					)}

					<div class="partnerships">
						<h3>In partnership with</h3>

						<div class="stack">
							{fundingPartnerInfos.map((partnerInfo) => (
								<a
									href={partnerInfo.url}
									target="_blank"
									rel="noopener noreferrer"
									class="squircle"
								>
									<img src={partnerInfo.src} alt={partnerInfo.alt} />
								</a>
							))}
						</div>
					</div>
				</div>
			)
		}

		<!-- Species Section -->
		{
			species.length > 0 && (
				<section class="trees">
					<h2>
						<Tree height={36} width={36} /> Species Planted
					</h2>
					<ul class="grid">
						{species.map((sp: any) => (
							<li>
								<span>{sp.name}</span>
							</li>
						))}
					</ul>
				</section>
			)
		}

		<!-- Site Updates Section -->
		{
			siteUpdates.length > 0 && (
				<section class="updates">
					<header>
						<h2>
							<PenField height={36} width={36} />
							Site Updates
						</h2>
					</header>

					<div class="updates-articles">
						{siteUpdates.map(({ data, bodyHtml }) => (
							<article class="update">
								<header>
									<h3>
										{data.date && (
											<time datetime={data.date.toISOString()}>
												{data.date.toLocaleDateString('en-GB', {
													year: 'numeric',
													month: 'long',
												})}
											</time>
										)}
									</h3>
								</header>

								<ul class="meta tags">
									{data.type && (
										<li class="tag" data-type="type">
											{data.type}
										</li>
									)}
									{data.treesPlanted && (
										<li class="tag" data-type="planted">
											<Tree height={18} width={18} /> {data.treesPlanted.toLocaleString()}
											trees planted
										</li>
									)}
									{data.treesRestocked && (
										<li class="tag" data-type="restocked">
											<Seedling height={18} width={18} /> {data.treesRestocked.toLocaleString()}
											trees restocked
										</li>
									)}
									{data.survivalRate != null && (
										<li class="tag" data-type="survival-rate">
											<Chart height={18} width={18} />
											{(data.survivalRate * 100).toFixed(0)}% survival rate
										</li>
									)}
								</ul>

								{bodyHtml && <div class="stack prose" set:html={bodyHtml} />}

								{data.photos && data.photos.length > 0 && (
									<div class="grid image-gallery">
										{data.photos.map((photo: any) => (
											<a href={photo.src} target="_blank" rel="noopener noreferrer" class="block">
												<Image
													src={photo}
													alt={`Site update photo for ${siteName}`}
													loading="lazy"
												/>
											</a>
										))}
									</div>
								)}
							</article>
						))}
					</div>
				</section>
			)
		}

		<!-- Map Section -->
		{
			coordinates && coordinates.latitude && coordinates.longitude && (
				<section>
					<h2>
						<MapPin height={36} width={36} /> Site Location
					</h2>
					<div id="map" class="map-canvas" />
				</section>
			)
		}
	</section>

	<TakeAction />
</Layout>

<style>
	h2 {
		font-size: var(--font-2xl);
		margin-block-end: var(--space-s);
	}

	h3 {
		font-size: var(--font-m);
		margin-block-end: var(--space-s);
	}

	.partnerships img {
		max-inline-size: 300px;
	}

	.intro {
		display: flex;
		flex-wrap: wrap;
		gap: var(--space-2xl);
	}

	.updates-articles {
		display: flex;
		flex-flow: column;
		gap: var(--space-xl);
	}

	.update {
		background: var(--white);
		padding: var(--space-m);
		border-radius: var(--radius-m);
		box-shadow: var(--shadow-lite);
	}

	.update:has(.image-gallery) .prose {
		margin-block-end: var(--space-m);
	}

	.trees ul {
		font-size: var(--font-m);
		grid-template-columns: var(--grid-fill);
	}

	.trees li {
		border: 2px solid var(--border-color);
		padding: var(--space-2xs);
		border-radius: var(--radius-s);
	}

	.meta {
		margin-block-end: var(--space-m);
	}

	.update h3 {
		font-size: var(--font-xl);
		margin-block-end: var(--space-s);
	}

	.image-gallery {
		grid-template-columns: var(--grid-fit-12rem);
	}

	.image-gallery a {
		max-inline-size: 100%;
		block-size: 100%;
	}

	.image-gallery img {
		border-radius: var(--radius-s);
		inset: 0;
		object-fit: cover;
		max-inline-size: 100%;
		block-size: 100%;
	}
</style>

<!-- Mapbox GL JS -->
<link href="https://api.mapbox.com/mapbox-gl-js/v2.8.2/mapbox-gl.css" rel="stylesheet" />
<script src="https://api.mapbox.com/mapbox-gl-js/v2.8.2/mapbox-gl.js"></script>

<script is:inline define:vars={{ coordinates, siteName, mapboxToken }}>
	if (coordinates && coordinates.latitude && coordinates.longitude) {
		document.addEventListener('DOMContentLoaded', () => {
			mapboxgl.accessToken = mapboxToken;

			const map = new mapboxgl.Map({
				container: 'map',
				style: 'mapbox://styles/mapbox/satellite-v9',
				center: [coordinates.longitude, coordinates.latitude],
				zoom: 15,
			});

			map.addControl(new mapboxgl.NavigationControl());

			new mapboxgl.Marker({ color: '#15803d' })
				.setLngLat([coordinates.longitude, coordinates.latitude])
				.addTo(map);
		});
	}
</script>
