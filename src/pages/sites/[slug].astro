---
import { getCollection } from 'astro:content';
import { Image } from 'astro:assets';
import { marked } from 'marked';
import ContentHero from '../../components/ContentHero.astro';
import ImageGallery from '../../components/ImageGallery.astro';
import TakeAction from '../../components/TakeAction.astro';
import { siteConfig } from '../../config';
import { toKebabCase } from '../../helpers';
import Layout from '../../layouts/Layout.astro';

export const prerender = true;

export async function getStaticPaths() {
	const apiResponse = await fetch('https://api.protect.earth/sites');
	const allApiSites = await apiResponse.json();

	// Filter out ignored sites
	const apiSites = allApiSites.filter((site: any) => !siteConfig.ignoredSites.includes(site.name));

	const siteCollection = await getCollection('siteMeta');

	// Create a map of API data by kebab-case name
	const apiDataMap = new Map();
	apiSites.forEach((site: any) => {
		const slug = toKebabCase(site.name);
		apiDataMap.set(slug, { ...site, slug });
	});

	return siteCollection.map((site) => {
		const apiData = apiDataMap.get(site.id);
		return {
			params: { slug: site.id },
			props: { site, apiData },
		};
	});
}

const { site, apiData } = Astro.props;

// If site is not found, return 404
if (!site) {
	return Astro.redirect('/404');
}

// Fetch site updates for this site
const allSiteUpdates = await getCollection('siteUpdates');
const siteNotionIds = site.data.notionIds || [];
const siteUpdates = await Promise.all(
	allSiteUpdates
		.filter((update) => update.data.siteNotionId && siteNotionIds.includes(update.data.siteNotionId))
		.map((siteUpdate) => ({
			...siteUpdate,
			data: {
				...siteUpdate.data,
				date: siteUpdate.data.date ? new Date(siteUpdate.data.date) : undefined,
			},
		}))
		.sort((a, b) => {
			if (!a.data.date) return 1;
			if (!b.data.date) return -1;
			return b.data.date.getTime() - a.data.date.getTime();
		})
		.map(async (update) => ({
			...update,
			bodyHtml: update.body ? await marked.parse(update.body) : '',
		})),
);

const mapboxToken = import.meta.env.PUBLIC_MAPBOX_TOKEN;

// Use API data for main info, fallback to collection data
const siteName = apiData?.name || site.id;
const siteLocation = apiData?.location || '';
const treeCount = apiData?.allocatedUnits || 0;
const coordinates = apiData?.coordinates;
// Use images directly from content collection
const images = site.data.images || [];
const heroImage = images[0]?.src || null;
const fundingPartners = site.data.fundingPartners || [];
const siteDescription = apiData?.description;
const descriptionHtml = siteDescription ? await marked.parse(siteDescription) : '';
const species = apiData?.species || [];

// Funding partner logo mapping
type FundingPartnerInfo = { src: string; alt: string; url: string };
const fundingPartnerLogos = {
	ecologi: {
		src: '/logos/funding/ecologi.png',
		alt: 'Ecologi',
		url: 'https://ecologi.com/',
	},
	'woodland-trust': {
		src: '/logos/funding/woodland-trust.png',
		alt: 'Woodland Trust',
		url: 'https://www.woodlandtrust.org.uk/',
	},
	reewild: {
		src: '/logos/funding/reewild.png',
		alt: 'Reewild',
		url: 'https://www.reewild.co.uk/',
	},
	earthpoints: {
		src: 'https://earthpoints.co.uk/wp-content/uploads/elementor/thumbs/earthpoints-logo-raqc5rj02uzbiv5arw3dkgg6s23ksaurwcha6ndgx4.jpg',
		alt: 'Earthpoints',
		url: 'https://earthpoints.co.uk/',
	},
} as Record<string, FundingPartnerInfo>;

const fundingPartnerInfos = fundingPartners
	.map((partner) => fundingPartnerLogos[partner])
	.filter(Boolean);
---

<Layout title={siteName} description={siteLocation}>
	<!-- Hero Section -->
	<ContentHero imageAlt="" imgSrc={heroImage} title={siteName}>
		<div>
			{siteLocation && <p>📍 {siteLocation}</p>}
			{treeCount > 0 && <p>🌳 {treeCount.toLocaleString()} trees planted</p>}
		</div>
	</ContentHero>

	<!-- Image Gallery -->
	<ImageGallery images={images} siteName={siteName} />

	{
		fundingPartnerInfos.length > 0 && (
			<div class="PageSection">
				<div class="PageSection__inner">
					{descriptionHtml && (
						<div
							class="prose readable-width inline-centered"
							data-readable-width="larger"
							set:html={descriptionHtml}
						/>
					)}

					<div class="SitePartners">
						<h3 class="SitePartners__title">In partnership with</h3>
						<ul class="SitePartners__list">
							{fundingPartnerInfos.map((partnerInfo) => (
								<li class="SitePartners__item">
									<a href={partnerInfo.url} target="_blank" rel="noopener noreferrer">
										<img src={partnerInfo.src} alt={partnerInfo.alt} />
									</a>
								</li>
							))}
						</ul>
					</div>
				</div>
			</div>
		)
	}

	<!-- Species Section -->
	{
		species.length > 0 && (
			<section class="SiteTreeSpecies">
				<div class="SiteTreeSpecies__inner">
					<h2 class="SiteTreeSpecies__title">
						<span>🌱</span>
						Species Planted
					</h2>
					<ul class="SiteTreeSpecies__grid">
						{species.map((sp: any) => (
							<li class="SiteTreeSpecies__tree">
								<span>{sp.name}</span>
							</li>
						))}
					</ul>
				</div>
			</section>
		)
	}

	<!-- Site Updates Section -->
	{
		siteUpdates.length > 0 && (
			<section class="PageSection SiteUpdates">
				<header class="PageSection__header">
					<h2 class="PageSection__title font-bold mb-8 text-gray-900">
						<span aria-hidden>📝</span>
						Site Updates
					</h2>
				</header>
				<div class="PageSection__content SiteUpdates__feed space-y-6">
					{siteUpdates.map(({ data, bodyHtml }) => (
						<article class="SiteUpdate">
							<header class="SiteUpdate__header">
								<h3 class="SiteUpdate__title">
									{data.date && (
										<time datetime={data.date.toISOString()}>
											{data.date.toLocaleDateString('en-GB', {
												year: 'numeric',
												month: 'long',
											})}
										</time>
									)}
								</h3>
							</header>

							<dl class="SiteUpdate__meta">
								{data.type && (
									<dt class="visually-hidden">Type</dt>
									<dd class="SiteUpdate__tag" data-type="type">{data.type}</dd>
								)}
								{data.treesPlanted && (
									<dt class="visually-hidden">Trees planted</dt>
									<dd class="SiteUpdate__tag" data-type="planted">
										<span aria-hidden>🌳</span> {data.treesPlanted.toLocaleString()}&nbsp;<span aria-hidden>trees planted</span>
									</dd>
								)}
								{data.treesRestocked && (
									<dt class="visually-hidden">Trees restocked</dt>
									<dd class="SiteUpdate__tag" data-type="restocked">
										<span aria-hidden>🌱</span> {data.treesRestocked.toLocaleString()}&nbsp;<span aria-hidden>trees restocked</span>
									</dd>
								)}
								{data.survivalRate != null && (
									<dt class="visually-hidden">Survival rate</dt>
									<dd class="SiteUpdate__tag" data-type="survival-rate">
										<span aria-hidden>📊</span> {(data.survivalRate * 100).toFixed(0)}%&nbsp;<span aria-hidden>survival rate</span>
									</dd>
								)}
							</dl>

							{bodyHtml && (
								<div class="SiteUpdate__body prose" set:html={bodyHtml} />
							)}

							{data.photos && data.photos.length > 0 && (
								<div class="SiteUpdate__photos">
									{data.photos.map((photo: any) => (
										<a href={photo.src} target="_blank" rel="noopener noreferrer" class="block">
											<Image src={photo} alt={`Site update photo for ${siteName}`} loading="lazy" />
										</a>
									))}
								</div>
							)}
						</article>
					))}
				</div>
			</section>
		)
	}

	<!-- Map Section -->
	{
		coordinates && coordinates.latitude && coordinates.longitude && (
			<section class="SiteLocation">
				<div class="container inline-centered">
					<h2 class="SiteLocation__title">Site Location</h2>
					<div id="map" class="MapCanvas" />
				</div>
			</section>
		)
	}

	<TakeAction />
</Layout>

<!-- Mapbox GL JS -->
<link href="https://api.mapbox.com/mapbox-gl-js/v2.8.2/mapbox-gl.css" rel="stylesheet" />
<script src="https://api.mapbox.com/mapbox-gl-js/v2.8.2/mapbox-gl.js"></script>

<script is:inline define:vars={{ coordinates, siteName, mapboxToken }}>
	if (coordinates && coordinates.latitude && coordinates.longitude) {
		document.addEventListener('DOMContentLoaded', () => {
			mapboxgl.accessToken = mapboxToken;

			const map = new mapboxgl.Map({
				container: 'map',
				style: 'mapbox://styles/mapbox/satellite-v9',
				center: [coordinates.longitude, coordinates.latitude],
				zoom: 15,
			});

			map.addControl(new mapboxgl.NavigationControl());

			new mapboxgl.Marker({ color: '#15803d' })
				.setLngLat([coordinates.longitude, coordinates.latitude])
				.addTo(map);
		});
	}
</script>
