---
import Layout from '../layouts/Layout.astro';
---

<Layout title="Privacy Policy">
	<section class="bg-green-700 text-white py-20">
		<div class="container mx-auto px-4 text-center">
			<h1 class="text-5xl font-bold mb-6">Privacy Policy</h1>
		</div>
	</section>

	<section class="py-16">
		<div class="container mx-auto px-4">
			<div class="prose prose-lg max-w-4xl mx-auto">
				<p>Protect Earth is committed to protecting your privacy. This privacy policy explains how we collect, use, and protect your personal information.</p>
			</div>
		</div>
	</section>
</Layout>
