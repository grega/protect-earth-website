---
import Layout from '../layouts/Layout.astro';
---

<Layout title="Events">
	<section class="bg-green-700 text-white py-20">
		<div class="container mx-auto px-4 text-center">
			<h1 class="text-5xl font-bold mb-6">Events</h1>
			<p class="text-xl max-w-3xl mx-auto">Upcoming volunteer events and activities</p>
		</div>
	</section>

	<section class="py-16">
		<div class="container mx-auto px-4">
			<div class="prose prose-lg max-w-4xl mx-auto">
				<p>Join us at one of our upcoming events. From tree planting to meadow maintenance, there's something for everyone.</p>
			</div>
		</div>
	</section>
</Layout>
