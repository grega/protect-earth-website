---
import ContentBlock from '../../components/ContentBlock.astro';
import ContentHero from '../../components/ContentHero.astro';
import TakeAction from '../../components/TakeAction.astro';
import Layout from '../../layouts/Layout.astro';
---

<Layout title="People & Families">
	<!-- Hero Section -->
	<ContentHero
		title="People & Families"
		imgSrc="/hero-people-families.jpg"
		imgAlt="Group of people outdoors planting trees on a hillside"
	>
		<p>
			Get stuck in and fight the climate and biodiversity crises. Whether you can offer your time,
			money, or expertise, there's a way for everyone to make a difference.
		</p>
	</ContentHero>

	<!-- Introduction Section -->
	<section class="py-16 bg-white">
		<div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
			<div class="grid md:grid-cols-2 gap-12 items-center">
				<div>
					<p class="text-xl text-gray-700 mb-6">
						Get stuck in and fight the climate and biodiversity crises. Whether you can offer your
						time, money, or expertise, there's a way for everyone to make a difference.
					</p>
					<p class="text-xl text-gray-700">
						Volunteers are the backbone of our charity, and with many hands, even the biggest tree
						planting jobs become manageable. We'll provide all the guidance you need to make the
						most of your volunteering with us, just bring a good attitude! These events are
						family-friendly and we welcome people of all ages and abilities.
					</p>
				</div>
				<div>
					<img
						src="/people-families-intro.jpg"
						alt="People planting small trees on a hillside with protective covers"
						class="w-full rounded-lg shadow-lg"
					/>
				</div>
			</div>
		</div>
	</section>

	<!-- Volunteering - Planting -->
	<ContentBlock
		imgSrc="/people-families-planting.jpg"
		imgAlt="Group of people planting trees in a field with mountains in the background"
		linkHref="/events"
		linkText="Browse Events →"
		title="Volunteering — Planting"
	>
		<p>
			Join one of our tree planting and seed sowing events! Tree planting season runs from October
			to March, and during this time we host multiple planting days where everyone is welcome to get
			involved.
		</p>
		<p>
			These events are a fantastic way to connect with nature, meet like-minded people, and directly
			contribute to reforestation efforts.
		</p>
	</ContentBlock>

	<!-- Volunteering - Maintenance -->
	<ContentBlock
		imgSrc="/people-families-maintenance.jpg"
		imgAlt="A group of people planting trees in a grassy field surrounded by trees."
		linkHref="/events"
		linkText="Browse Events →"
		title="Volunteering — Maintenance"
		isReversed
	>
		<p>
			Outside of planting season, we focus on maintaining the trees to ensure they thrive. Join us
			for sessions where we weed, mulch, and water during droughts.
		</p>
		<p>
			You can also help with vital tasks like removing invasive species to make room for native
			plants or participating in litter picks to protect wildlife from harmful plastics. Every
			action makes a huge impact.
		</p>
	</ContentBlock>

	<!-- Donations & Fundraising -->
	<ContentBlock
		imgAlt="Group of people planting trees in a grassy field."
		imgSrc="/people-families-fundraising.jpg"
		title="Donations & Fundraising"
		linkHref="/contact"
		linkText="Contact Us →"
	>
		<p>
			There are lots of ways you can help fund our charity. Please consider
			<a href="/act-now/general-donation">donating</a>,
			<a href="/act-now/sponsor-trees">sponsoring a tree</a>, or contributing to our
			<a href="/act-now/land-fund">Land Fund</a>. Want to take it a step further? Embark on a
			personal challenge, or encourage your company to pledge 1% for the planet. If you have any
			novel ideas you'd like to discuss, please get in touch.
		</p>
	</ContentBlock>

	<!-- Buy More Land for Planting -->
	<ContentBlock
		imgAlt="Rolling green hills with scattered trees and stone walls in a rural landscape"
		imgSrc="/people-families-land.jpg"
		linkHref="/people-and-families/well-help-you-buy-land"
		linkText="See More →"
		title="Buy More Land for Planting"
		isReversed
	>
		<p>
			We are delighted to be able to offer our expert services to help you secure the correct land
			for reforesting, rewetting or rewilding.
		</p>
	</ContentBlock>

	<TakeAction />
</Layout>
