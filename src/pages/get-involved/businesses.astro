---
import Layout from '../../layouts/Layout.astro';
import CallToAction from '../../components/CallToAction.astro';
---

<Layout title="Businesses">
	<!-- Hero Section -->
	<section class="relative bg-gray-900 text-white">
		<div class="absolute inset-0">
			<img src="/hero-businesses.jpg" alt="Two women planting trees in a field" class="w-full h-full object-cover opacity-60" />
		</div>
		<div class="relative max-w-4xl mx-auto px-4 sm:px-6 lg:px-8 py-24 text-center">
			<h1 class="text-5xl font-bold mb-6">Businesses</h1>
			<p class="text-xl md:text-2xl leading-relaxed max-w-3xl mx-auto">
				Ready to branch out? We offer businesses the chance to create lasting environmental impact while building stronger teams and greener communities. Whether planting trees with your colleagues, revitalising unused land or donating to our cause, we make it easy to level up your sustainability strategy.
			</p>
		</div>
	</section>

	<!-- Brand Logos Section -->
	<section class="py-20 bg-gray-50">
		<div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
			<h2 class="text-3xl md:text-4xl font-bold mb-12 text-center">Some brands who have benefited from supporting us:</h2>
			<div class="grid grid-cols-2 md:grid-cols-4 lg:grid-cols-7 gap-8 items-center justify-items-center grayscale opacity-60">
				<img src="/brand-absolute-vodka.png" alt="Absolut Vodka" class="h-16 w-auto object-contain" />
				<img src="/brand-acer.png" alt="Acer" class="h-16 w-auto object-contain" />
				<img src="/brand-capsule-cover.png" alt="Capsule Cover" class="h-16 w-auto object-contain" />
				<img src="/brand-environment-agency.png" alt="Environment Agency" class="h-16 w-auto object-contain" />
				<img src="/brand-google.png" alt="Google" class="h-16 w-auto object-contain" />
				<img src="/brand-ovo-energy.png" alt="Ovo Energy" class="h-16 w-auto object-contain" />
				<img src="/brand-reuseabox.png" alt="Reuseabox" class="h-16 w-auto object-contain" />
			</div>
		</div>
	</section>

	<!-- Corporate Volunteering Section -->
	<section class="py-20 bg-white">
		<div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
			<div class="grid grid-cols-1 lg:grid-cols-2 gap-12 items-center">
				<div>
					<img src="/businesses-volunteering.jpg" alt="People planting young trees in a grassy field" class="w-full rounded-lg shadow-lg" />
				</div>
				<div>
					<h2 class="text-3xl md:text-4xl font-bold mb-6">Corporate Volunteering</h2>
					<div class="prose prose-lg text-gray-700 space-y-4">
						<p>
							Escape the office and bring your team out for a unique, environmentally-friendly experience! Our tree planting days offer the perfect opportunity for team building while supporting our mission.
						</p>
						<p>
							Many companies have joined us for these events, and together, we've planted as many as 2,000 trees in a single day!
						</p>
						<p>
							Not only is this a rewarding way to contribute to your local area, but it's also a fantastic chance to capture some fun content for your socials. Our eco-experts will guide your team through the day – from what to bring, to the basics of tree planting, to carbon-reducing tips they can apply at home.
						</p>
					</div>
					<div class="mt-8">
						<a href="https://protectearthcio.notion.site/2c1e7dc6657c80d3b21ff727acd31056" target="_blank" rel="noopener noreferrer" class="inline-block bg-green-700 hover:bg-green-800 text-white font-bold px-8 py-4 rounded transition text-lg">
							Get Started →
						</a>
					</div>
				</div>
			</div>
		</div>
	</section>

	<!-- Sponsor Reforestation Section -->
	<section class="py-20 bg-gray-50">
		<div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
			<div class="grid grid-cols-1 lg:grid-cols-2 gap-12 items-center">
				<div class="order-2 lg:order-1">
					<h2 class="text-3xl md:text-4xl font-bold mb-6">Sponsor Reforestation & Rewilding</h2>
					<div class="prose prose-lg text-gray-700 space-y-4">
						<p>
							Most of the work we do is done without government grants or any other form of funding, and donations only get us so far. Companies who want to plant trees or improve biodiversity in their area can sponsor an entire project, or a certain number of trees, or square meters of other work like ancient woodland restoration.
						</p>
						<p>
							This helps boost your company's sustainability credentials, demonstrate a commitment to combating climate change, and you can come out to help do the work if you fancy it.
						</p>
					</div>
					<div class="mt-8">
						<a href="/contact" class="inline-block bg-green-700 hover:bg-green-800 text-white font-bold px-8 py-4 rounded transition text-lg">
							Contact Us →
						</a>
					</div>
				</div>
				<div class="order-1 lg:order-2">
					<img src="/businesses-sponsor1.jpg" alt="People planting trees on a grassy hillside" class="w-full rounded-lg shadow-lg" />
				</div>
			</div>
		</div>
	</section>

	<!-- Planting Your Land Section -->
	<section class="py-20 bg-white">
		<div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
			<div class="grid grid-cols-1 lg:grid-cols-2 gap-12 items-center">
				<div>
					<img src="/businesses-sponsor2.jpg" alt="Group of people planting trees in a field" class="w-full rounded-lg shadow-lg" />
				</div>
				<div>
					<h2 class="text-3xl md:text-4xl font-bold mb-6">Planting Your Land</h2>
					<div class="prose prose-lg text-gray-700 space-y-4">
						<p>
							Got land sitting idle? Turn it into a productive carbon store and thriving habitat for wildlife!
						</p>
						<p>
							Whether you're a small business with a back garden or a large corporation with acres to spare, we can help transform your unused land into something extraordinary. Our ecologists will design a plan tailored to your site's potential, and be your guides in planting and ongoing maintenance.
						</p>
					</div>
					<div class="mt-8">
						<a href="/contact" class="inline-block bg-green-700 hover:bg-green-800 text-white font-bold px-8 py-4 rounded transition text-lg">
							Contact Us →
						</a>
					</div>
				</div>
			</div>
		</div>
	</section>

	<CallToAction />
</Layout>
